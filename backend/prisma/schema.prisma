generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ここから下がデータベースのテーブル設計です ---

// 授業
model Class {
  id        Int        @id @default(autoincrement())
  name      String
  year      Int
  semester  String
  color     String
  tasks     Task[]
  templates Template[]
}

// 課題
model Task {
  id            Int      @id @default(autoincrement())
  title         String
  dueDate       DateTime
  estimatedTime Int
  memo          String?
  isCompleted   Boolean  @default(false)
  classId       Int
  class         Class    @relation(fields: [classId], references: [id])
}

// テンプレート
model Template {
  id            Int      @id @default(autoincrement())
  title         String
  estimatedTime Int
  memo          String?
  classId       Int
  class         Class    @relation(fields: [classId], references: [id])
}